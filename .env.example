# ── GTM Pipeline — BYOK environment ──────────────────────────────────────────
# Copy this file to `.env` and fill in ONLY the providers you have keys for.
#
# Secrets are read from your LOCAL environment only. This framework NEVER fetches
# keys over the network. Load them before invoking the pipeline, e.g.:
#
#     set -a && source .env && set +a
#
# Do NOT commit your `.env`. (It is gitignored.)
#
# Provider discovery is automatic: a provider is only used if its env var below is
# set and non-empty AND it appears in a waterfall in gtm.config.yaml. Unset keys
# are skipped with a one-line log — so a partial key set still gives a working,
# thinner pipeline.

# ── Storage (postgres backend only — omit entirely if using the local backend) ─
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# ── Sourcing / search ────────────────────────────────────────────────────────
APOLLO_API_KEY=
APIFY_TOKEN=
DROPLEADS_API_KEY=

# ── Email + phone enrichment ─────────────────────────────────────────────────
FULLENRICH_API_KEY=
CLEAROUTPHONE_API_KEY=

# ── Sequencing / activation ──────────────────────────────────────────────────
LEMLIST_API_KEY=

# ── Premium / alternative providers (uncomment to wire in via gtm.config.yaml) ─
# PROSPEO_API_KEY=          # full single-provider stack: company/people search + email + mobile + company intel
# SMARTLEAD_API_KEY=        # email sequencer (alternative to lemlist)
# HEYREACH_API_KEY=         # LinkedIn sequencer (leads must have a LinkedIn URL)
# FIRECRAWL_API_KEY=        # optional cleaner "eyes" for company_enrich (scrape/extract)

# ── CRM dedupe (optional — suppress accounts/people already in your CRM) ───────
# HUBSPOT_TOKEN=            # HubSpot Private App token (crm.objects.*.read scopes), read-only
